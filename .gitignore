# ─── Secrets — NEVER commit these ─────────────────────────────────────────────
.env
.env.local
.env.*.local
contract/.env
frontend/.env.local

# ─── Foundry / Contract build artifacts ───────────────────────────────────────
contract/out/
contract/cache/
contract/broadcast/
# Keep the broadcast folder structure but ignore actual run files
!contract/broadcast/.gitkeep

# ─── Node / Frontend ──────────────────────────────────────────────────────────
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/.turbo/
frontend/tsconfig.tsbuildinfo

# ─── OS & Editor ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Misc ─────────────────────────────────────────────────────────────────────
*.pem
*.key
lcov.info
coverage/
