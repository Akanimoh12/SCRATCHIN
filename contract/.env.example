# ─────────────────────────────────────────────────────────────────────────────
# SCRATCHIN' — Contract deployment environment variables
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your values below
# 3. NEVER commit .env — it is gitignored
# ─────────────────────────────────────────────────────────────────────────────

# ── Deployer wallet ──────────────────────────────────────────────────────────
# Export your private key from MetaMask: Account Details → Export Private Key
# This wallet needs testnet ETH on BOTH Unichain Sepolia AND Reactive Lasna.
#   - Unichain Sepolia ETH: https://faucet.unichain.org
#   - Reactive Lasna ETH:   https://dev.reactive.network/docs/faucet
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# ── RPC endpoints ────────────────────────────────────────────────────────────
# These are the current working endpoints — no need to change them.
UNICHAIN_SEPOLIA_RPC=https://sepolia.unichain.org
REACTIVE_LASNA_RPC=https://lasna-rpc.rnk.dev

# ── USDC address (Unichain Sepolia) ──────────────────────────────────────────
# This is the official USDC on Unichain Sepolia (6 decimals).
# Verify at: https://unichain-sepolia.blockscout.com/address/0x31d0220469e10c4E71834a79b1f276d740d3768F
USDC_ADDRESS=0x31d0220469e10c4E71834a79b1f276d740d3768F

# ── Prize pool seed ──────────────────────────────────────────────────────────
# How much USDC (in 6-decimal units) to seed the jackpot with on deploy.
# 20_000_000 = 20 USDC. Set to 0 to skip.
# Your wallet must hold at least this much USDC on Unichain Sepolia.
# Get testnet USDC from the Unichain faucet or bridge.
SEED_AMOUNT=20000000

# ── Post-deploy addresses (filled in after forge script runs) ─────────────────
# After running Deploy.s.sol, paste the printed addresses here before running
# DeployReactive.s.sol and before setting up the frontend .env.local.
SCRATCH_CARD_ADDRESS=0xd051dD659844CFe4e2093a357368c57fe7d0a3c4
PRIZE_POOL_ADDRESS=0xd7F50EaAEf4CcC922816261C142E3e1581dB9f3c
REFERRAL_ADDRESS=0xB830f8634d10a5B4F8FE16d70D531034AE4cA668
REACTIVE_RSC_ADDRESS=0x77ec0037Bf4928BeaC8Cb943D249b0045209C464

# ── Block explorer verification ───────────────────────────────────────────────
# Optional. Get a free API key at:
# https://unichain-sepolia.blockscout.com/account/api-key
ETHERSCAN_API_KEY=your_blockscout_api_key_here
